NEXT_PUBLIC_SITE_URL=https://printzcom.vercel.app
NEXT_PUBLIC_ETSY_URL=https://www.etsy.com/shop/YOURSHOPNAME
NEXT_PUBLIC_CONTACT_EMAIL=hello@example.com
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_TIKTOK_URL=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_EMAILS=you@example.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_RESEARCH_MODEL=gpt-4.1-mini

# Etsy Open API v3 sync
# x-api-key value should be keystring:shared_secret from your Etsy developer app.
# OAuth scopes used by the app: listings_r listings_w shops_r shops_w transactions_r.
ETSY_API_KEY=
ETSY_ACCESS_TOKEN=
ETSY_SHOP_ID=
ETSY_SHOP_NAME=printzbykhan
ETSY_DEFAULT_TAXONOMY_ID=
ETSY_SHIPPING_PROFILE_ID=
ETSY_READINESS_STATE_ID=
# When true, saving an existing website product with an attached Etsy listing also pushes listing field updates to Etsy.
ETSY_AUTO_SYNC_ON_PRODUCT_SAVE=false
# Optional override for the external hourly Etsy draft scheduler. Falls back to CRON_SECRET.
ETSY_DRAFT_CRON_SECRET=
CRON_SECRET=

# Deterministic PRINTZ product command-center sync
PRODUCT_SYNC_SECRET=
PRINTZ_PRODUCT_SHEET_ID=14L2liBREJYQSO_rhaAon_1RXonZIah91y77f4T3ctXs
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Alternative: GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Optional parent Drive folder containing one child folder per product. Used as fallback when Drive Media Folder URL is blank.
PRINTZ_PRODUCT_MEDIA_PARENT_FOLDER_URL=
